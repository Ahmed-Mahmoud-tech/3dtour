# Server Environment Variables
# Copy this file to .env and fill in your values

PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/photovideo360

# JWT Secret - use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Upload Limits (in bytes)
MAX_IMAGE_SIZE=52428800
MAX_VIDEO_SIZE=524288000

# FFmpeg binary path (leave empty to use system PATH)
FFMPEG_PATH=

# Email (subscription reminder emails). Leave SMTP_PASS empty to disable
# outgoing mail (reminders still create admin notifications).
# Dev sends from ahmedmahmoudtech@gmail.com (Gmail app password);
# production sends from contact@gateverse.net. EMAIL_FROM overrides the
# NODE_ENV-based default.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=ahmedmahmoudtech@gmail.com
SMTP_PASS=
EMAIL_FROM=
