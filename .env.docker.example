# Copy to .env — docker compose reads it for variable substitution.
#   cp .env.docker.example .env

# REQUIRED — long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Public origins allowed by CORS (host ports the browser hits).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Upload size caps (bytes)
MAX_IMAGE_SIZE=52428800
MAX_VIDEO_SIZE=524288000

# Email for subscription reminders. Leave SMTP_PASS empty to disable outgoing
# mail (reminders still create in-app admin notifications).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# Mailbox that receives client replies (the From domain may have no MX).
EMAIL_REPLY_TO=

# ── Production only (docker-compose.prod.yml) ────────────────────────────────
# Host ports for the two frontends (API stays internal).
#CLIENT_PORT=80
#ADMIN_PORT=8080
# Image tag to run; CI overrides this per deploy with the git sha.
#IMAGE_TAG=latest

# ── Backups (backup service — see OPS.md) ────────────────────────────────────
#BACKUP_HOUR_UTC=3
#BACKUP_RETENTION_DAYS=14
#BACKUP_UPLOADS=1
#UPLOADS_KEEP=4

# ── Monitoring (docker-compose.monitoring.yml) ───────────────────────────────
# 127.0.0.1 = SSH-tunnel access only (default, recommended — Netdata has no auth).
#MONITOR_BIND=127.0.0.1
