# Copy to .env — docker compose reads it for variable substitution.
#   cp .env.docker.example .env

# REQUIRED — long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Public origins allowed by CORS (host ports the browser hits).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Upload size caps (bytes)
MAX_IMAGE_SIZE=52428800
MAX_VIDEO_SIZE=524288000

# Email for subscription reminders. Leave SMTP_PASS empty to disable outgoing
# mail (reminders still create in-app admin notifications).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
