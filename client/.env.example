# Client (Next.js) environment — copy to .env.local and fill in.
# Only NEXT_PUBLIC_* values are exposed to the browser (inlined at build time).

# API base for the browser. Falls back to "/api" (Next rewrites proxy it to the
# server), so you usually don't need to set this.
# NEXT_PUBLIC_API_URL=/api

# Where the deployed tour viewer lives, used by the landing portfolio links.
# Empty = same origin.
# NEXT_PUBLIC_VIEWER_URL=

# Express API origin the Next dev/prod server proxies /api and /uploads to.
# SERVER_ORIGIN=http://localhost:5000

# --- Marketing analytics (landing pages only) ---------------------------------
# Leave blank and nothing loads. Set them to switch on ad-conversion tracking.
# Google Analytics 4 measurement id (Admin > Data Streams).
NEXT_PUBLIC_GA_ID=
# Meta (Facebook) Pixel id (Events Manager > Data Sources).
NEXT_PUBLIC_FB_PIXEL_ID=
